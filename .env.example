# ============================================================
# CONFIGURAÇÃO DO BOT SEAP v2
# ============================================================
# COMO USAR:
#   1. Renomeie este arquivo de ".env.example" para ".env"
#   2. Preencha os valores abaixo com suas informações reais
#   3. NUNCA envie o arquivo .env para o GitHub (tem sua senha!)
# ============================================================

# Chave da API do CapSolver
# Pegue em: https://dashboard.capsolver.com/
CAPSOLVER_API_KEY=cole_sua_chave_aqui

# Credenciais SEAP-RJ
SEAP_USERNAME=seu_usuario_seap
SEAP_PASSWORD=sua_senha_seap

# Parâmetros do filtro de vagas (página 2 — opcional)
# Deixe vazio para pular a segunda página
SEAP_FILTER_UNIT=
SEAP_FILTER_DATE=

# Dashboard Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_SECRET=seap-bot-secret-key-2026
